{
    "version": 2,
    "builds": [
        {
            "src": "backend/index.js",
            "use": "@vercel/node"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/index.js"
        }
    ],
    "functions": {
        "backend/index.js": {
            "maxDuration": 60
        }
    }
}